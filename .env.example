# -------------------------------------------------------------
# AI Sales Forecasting Dashboard — Environment Variables
# -------------------------------------------------------------
# Copy this file to .env and fill in your values.
# DO NOT commit your real .env file to version control!

# 1. Database Connection (Required)
# Your Supabase PostgreSQL connection string.
# Use the Session Pooler (port 6543) for serverless environments.
# Percent-encode special characters in the password.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:6543/postgres?sslmode=require"

# 2. Security / Authentication (Required)
# Used to sign JWT authentication tokens.
SECRET_KEY="your-super-secure-random-secret-key-here"

# 3. Flask Environment (Optional, defaults to "production")
FLASK_ENV="development"

# 4. CORS Configuration (Optional)
# Comma-separated list of additional origins allowed to access the API.
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# 5. Frontend API Base URL (Optional, used by Vite build)
VITE_API_BASE_URL="/api"

# 6. Machine Learning Model Path (Required)
MODEL_PATH="models/sales_model.pkl"
